# Example .env for JurisAI server

# Server Port
PORT=5000

# MongoDB
# MONGODB_URI=mongodb://127.0.0.1:27017/jurisai
# or Atlas connection string
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority&appName=Cluster0

# SMTP configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_app_password_here
MAIL_FROM="JurisAI <youraddress@gmail.com>"

# Contact form admin email (where contact form submissions go)
MAIL_TO=admin@yourdomain.com

# Environment
NODE_ENV=development

# Demo credentials for testing
DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=password123

# Gemini API Key for AI Responses
GEMINI_API_KEY=your-gemini-api-key
