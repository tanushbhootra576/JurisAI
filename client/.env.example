# Client Environment Variables (Optional)
# Vite automatically loads .env files

# API Base URL (optional - only needed for production)
# In development, axios.defaults.baseURL is set to http://localhost:5000
# VITE_API_URL=https://your-api-domain.com

# Other optional environment variables
# VITE_APP_NAME=JurisAI

# Demo credentials for testing
VITE_DEMO_EMAIL=demo@example.com
VITE_DEMO_PASSWORD=password123
